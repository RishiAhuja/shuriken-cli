{
  "name": "create-shuriken",
  "version": "1.0.2",
  "description": "Scaffold a new Shuriken Next.js project with a sharp TUI",
  "type": "module",
  "bin": {
    "create-shuriken": "./dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "templateVersion": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shuriken",
    "nextjs",
    "starter",
    "template",
    "cli",
    "scaffold"
  ],
  "author": "Rishi Ahuja",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RishiAhuja/shuriken-cli.git"
  },
  "homepage": "https://github.com/RishiAhuja/shuriken-cli#readme",
  "bugs": {
    "url": "https://github.com/RishiAhuja/shuriken-cli/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "validate-npm-package-name": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
